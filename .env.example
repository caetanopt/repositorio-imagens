APP_NAME="Repositório de Imagens"
APP_URL=https://media.apps.caetano.pt
APP_ENV=production
APP_DEBUG=false

DB_HOST=localhost
DB_PORT=3306
DB_NAME=repositorio_imagens
DB_USER=
DB_PASS=

STORAGE_PATH=/var/www/media.apps.caetano.pt/storage/images
SESSION_LIFETIME=7200
REMEMBER_ME_DAYS=30

UPLOAD_MAX_SIZE_MB=20
UPLOAD_MAX_FILES=20
